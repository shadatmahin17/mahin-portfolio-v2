rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety catch-all: Default deny everything
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Path Variable Hardening (ID Poisoning Guard)
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // System Administrator check using runtime email validation
    function isAdmin() {
      return request.auth != null 
        && request.auth.token.email_verified == true 
        && request.auth.token.email == 'mahinaurwave12@gmail.com';
    }

    // Strict Contact Validation Blueprint
    function isValidContact(data) {
      return data.keys().hasAll(['name', 'email', 'subject', 'message', 'createdAt'])
        && data.keys().size() == 5
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() >= 3 && data.email.size() <= 100
        && data.subject is string && data.subject.size() <= 200
        && data.message is string && data.message.size() > 0 && data.message.size() <= 5000
        && data.createdAt == request.time;
    }

    // Contacts collection configuration matching the firebase-blueprint model
    match /contacts/{contactId} {
      allow create: if isValidId(contactId) && isValidContact(request.resource.data);
      allow read, list: if isAdmin();
      allow update, delete: if false;
    }
  }
}
